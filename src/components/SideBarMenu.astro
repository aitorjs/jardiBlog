---
const { sideBarActiveItemID } = Astro.props;
const activeClass = "bg-base-300"; // For primary color replace with `active` class
---

<ul class="menu grow shrink menu-md overflow-y-auto w-full">
  <li>
    <a
      class={`py-3 text-base ${sideBarActiveItemID === "home" ? activeClass : ""}`}
      href="/">Inicio</a
    >
  </li>
  <li>
    <a
      class={`py-3 text-base ${sideBarActiveItemID === "blog" ? activeClass : ""}`}
      href="/blog/">Blog</a
    >
  </li>
  <li>
    <a
      class={`py-3 text-base ${sideBarActiveItemID === "gallery" ? activeClass : ""}`}
      href="/gallery">Galería</a
    >
  </li>
  <li>
    <a
      class={`py-3 text-base ${sideBarActiveItemID === "cv" ? activeClass : ""}`}
      href="/cv">CV</a
    >
  </li>
  <li>
    <a
      class="py-3 text-base"
      href="mailto:aitori@ni.eus"
      target="_blank"
      referrerpolicy="no-referrer-when-downgrade">Contacto</a
    >
  </li>
</ul>
