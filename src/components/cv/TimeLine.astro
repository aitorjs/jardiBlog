---
const { title, subtitle, data } = Astro.props;
---

<div class="flex">
  <div class="education__time">
    <span class="w-4 h-4 bg-primary block rounded-full mt-1"></span>
    <span
      class="education__line bg-primary block h-full w-[2px] translate-x-[7px]"
    ></span>
  </div>
  <div class="experience__data bd-grid px-5">
    <p class="text-lg font-light">{data}</p>
    <h3 class="font-semibold text-xl mb-1">{title}</h3>
    <span class="text-lg" set:html={subtitle} />
    <p class="mb-4 text-lg">
      <slot />
    </p>
  </div>
</div>
