---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getImage } from "astro:assets";
import galleryMeta from "../data/gallery.json";

const title = "Galería";
const description = "Fotos del jardín";

const imageFiles = import.meta.glob("../assets/gallery/*.{jpg,jpeg,png,webp}", {
  eager: true,
});

const photos = await Promise.all(
  galleryMeta.map(async (item) => {
    const entry = Object.entries(imageFiles).find(([path]) =>
      path.includes(`/${item.id}.`),
    );
    if (!entry) {
      throw new Error(
        `No se encontró la imagen para "${item.id}" en src/assets/gallery`,
      );
    }
    const source = entry[1].default;

    const full = await getImage({
      src: source,
      width: 1600,
      format: "webp",
      quality: 80,
    });
    const thumb = await getImage({
      src: source,
      width: 500,
      height: 500,
      fit: "cover",
      format: "webp",
      quality: 70,
    });

    return {
      ...item,
      src: full.src,
      thumbSrc: thumb.src,
      width: full.attributes.width,
      height: full.attributes.height,
    };
  }),
);
---

<BaseLayout
  title={title}
  description={description}
  sideBarActiveItemID="gallery"
>
  <div class="mb-6">
    <h1 class="text-2xl font-bold">Fotos de la huerta, balcón y demás</h1>
  </div>

  <section>
    <div class="grid grid-cols-2 gap-2 sm:grid-cols-3 sm:gap-3 lg:grid-cols-4">
      {
        photos.map((photo, i) => (
          <button
            class="gallery-item group relative aspect-square overflow-hidden rounded-xl bg-base-2                                                                                                                         00"
            data-index={i}
            aria-label={`Ver foto: ${photo.title}`}
          >
            <img
              src={photo.thumbSrc}
              alt={photo.title}
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
            />
          </button>
        ))
      }
    </div>
  </section>

  <!-- Visor / Lightbox -->
  <div id="lightbox" class="fixed inset-0 z-50 hidden flex-col bg-black/95">
    <div class="flex items-center justify-between p-3 text-white sm:p-4">
      <span id="lb-counter" class="text-sm opacity-70"></span>
      <div class="flex items-center gap-1">
        <button
          id="lb-info-toggle"
          aria-label="Más información"
          class="btn btn-ghost btn-circle btn-sm text-white"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            class="h-5 w-5"
          >
            <circle cx="12" cy="12" r="9"></circle>
            <line x1="12" y1="11" x2="12" y2="16"></line>
            <circle cx="12" cy="8" r="0.5" fill="currentColor"></circle>
          </svg>
        </button>
        <button
          id="lb-close"
          aria-label="Cerrar"
          class="btn btn-ghost btn-circle btn-sm text-white"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            class="h-5 w-5"
          >
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
    </div>

    <div
      id="lb-stage"
      class="relative flex flex-1 items-center justify-center overflow-hidden"
    >
      <button
        id="lb-prev"
        aria-label="Anterior"
        class="btn btn-ghost btn-circle absolute left-2 top-1/2 hidden -translate-y-1/2 text-white sm:flex"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          class="h-6 w-6"><polyline points="15 18 9 12 15 6"></polyline></svg
        >
      </button>

      <img
        id="lb-img"
        src=""
        alt=""
        draggable="false"
        class="max-h-[75vh] max-w-[92vw] select-none object-contain"
      />

      <button
        id="lb-next"
        aria-label="Siguiente"
        class="btn btn-ghost btn-circle absolute right-2 top-1/2 hidden -translate-y-1/2 text-white sm:flex"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          class="h-6 w-6"><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </button>
    </div>

    <div
      id="lb-info"
      class="absolute inset-x-0 bottom-0 max-h-[45vh] overflow-y-auto rounded-t-2xl bg-base-100 p-5 pb-8 text-base-content"
    >
      <div class="mx-auto mb-3 h-1.5 w-10 rounded-full bg-base-300 sm:hidden">
      </div>
      <h3 id="lb-title" class="text-lg font-bold"></h3>
      <p id="lb-desc" class="mt-1 text-sm opacity-80"></p>
      <div id="lb-tags" class="mt-3 flex flex-wrap gap-2"></div>
    </div>
  </div>
</BaseLayout>

<style>
  #lb-info {
    transform: translateY(100%);
    transition: transform 0.3s ease;
  }
  #lb-info.open {
    transform: translateY(0);
  }
  /* El icono de info solo tiene sentido si no hay gesto táctil disponible */
  @media (pointer: coarse) {
    #lb-info-toggle {
      display: none;
    }
  }
  ::view-transition-old(gallery-photo),
  ::view-transition-new(gallery-photo) {
    animation-duration: 0.35s;
  }
</style>

<script define:vars={{ photos }}>
  function setupGallery() {
    const items = Array.from(document.querySelectorAll(".gallery-item"));
    const lightbox = document.getElementById("lightbox");
    const stage = document.getElementById("lb-stage");
    const lbImg = document.getElementById("lb-img");
    const lbTitle = document.getElementById("lb-title");
    const lbDesc = document.getElementById("lb-desc");
    const lbTags = document.getElementById("lb-tags");
    const lbCounter = document.getElementById("lb-counter");
    const infoPanel = document.getElementById("lb-info");
    const btnClose = document.getElementById("lb-close");
    const btnInfo = document.getElementById("lb-info-toggle");
    const btnPrev = document.getElementById("lb-prev");
    const btnNext = document.getElementById("lb-next");

    let current = 0;
    let infoOpen = false;

    function canAnimate() {
      return (
        typeof document.startViewTransition === "function" &&
        !window.matchMedia("(prefers-reduced-motion: reduce)").matches
      );
    }

    function clearNames() {
      items.forEach((el) => (el.style.viewTransitionName = ""));
    }

    function render() {
      const p = photos[current];
      lbImg.src = p.src;
      lbImg.alt = p.title;
      lbImg.style.aspectRatio = `${p.width} / ${p.height}`;
      lbTitle.textContent = p.title;
      lbDesc.textContent = p.description;
      lbTags.innerHTML = "";
      (p.tags || []).forEach((tag) => {
        const span = document.createElement("span");
        span.className = "badge badge-outline badge-sm";
        span.textContent = `#${tag}`;
        lbTags.appendChild(span);
      });
      lbCounter.textContent = `${current + 1} / ${photos.length}`;
    }

    function withTransition(sourceIndex, mutate) {
      if (canAnimate()) {
        clearNames();
        const sourceEl = items[sourceIndex];
        if (sourceEl) sourceEl.style.viewTransitionName = "gallery-photo";
        lbImg.style.viewTransitionName = "gallery-photo";
        const transition = document.startViewTransition(mutate);
        transition.finished.finally(() => {
          clearNames();
          lbImg.style.viewTransitionName = "";
        });
      } else {
        mutate();
      }
    }

    function open(index) {
      withTransition(index, () => {
        current = index;
        render();
        lightbox.classList.remove("hidden");
        lightbox.classList.add("flex");
        document.body.style.overflow = "hidden";
      });
    }

    function close() {
      infoOpen = false;
      infoPanel.classList.remove("open");
      withTransition(current, () => {
        lightbox.classList.add("hidden");
        lightbox.classList.remove("flex");
        document.body.style.overflow = "";
      });
    }

    function go(delta) {
      const newIndex = (current + delta + photos.length) % photos.length;
      withTransition(newIndex, () => {
        current = newIndex;
        render();
      });
    }

    function toggleInfo(force) {
      infoOpen = force !== undefined ? force : !infoOpen;
      infoPanel.classList.toggle("open", infoOpen);
    }

    items.forEach((btn, i) => {
      btn.addEventListener("click", () => open(i));
    });

    btnClose.addEventListener("click", close);
    btnInfo.addEventListener("click", () => toggleInfo());
    btnPrev.addEventListener("click", () => go(-1));
    btnNext.addEventListener("click", () => go(1));

    lightbox.addEventListener("click", (e) => {
      if (e.target === lightbox) close();
    });

    document.addEventListener("keydown", (e) => {
      if (lightbox.classList.contains("hidden")) return;
      if (e.key === "Escape") close();
      if (e.key === "ArrowRight") go(1);
      if (e.key === "ArrowLeft") go(-1);
      if (e.key === "ArrowUp") toggleInfo(true);
      if (e.key === "ArrowDown") toggleInfo(false);
    });

    // Gestos táctiles: arriba = info, abajo = cerrar info / cerrar visor, izq-dcha = anterior/siguiente
    let touchStartX = 0;
    let touchStartY = 0;
    let touching = false;

    stage.addEventListener(
      "touchstart",
      (e) => {
        touching = true;
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
      },
      { passive: true },
    );

    stage.addEventListener(
      "touchend",
      (e) => {
        if (!touching) return;
        touching = false;
        const dx = e.changedTouches[0].clientX - touchStartX;
        const dy = e.changedTouches[0].clientY - touchStartY;
        const absX = Math.abs(dx);
        const absY = Math.abs(dy);
        const threshold = 45;
        if (absX < threshold && absY < threshold) return;

        if (absY > absX) {
          if (dy < 0) toggleInfo(true);
          else if (!infoOpen) close();
          else toggleInfo(false);
        } else {
          if (dx < 0) go(1);
          else go(-1);
        }
      },
      { passive: true },
    );
  }

  document.addEventListener("astro:page-load", setupGallery);
</script>
