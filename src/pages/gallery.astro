---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getImage } from "astro:assets";
import galleryMeta from "../data/gallery.json";

const title = "Galería";
const description = "Fotos del jardín";

const imageFiles = import.meta.glob("../assets/gallery/*.{jpg,jpeg,png,webp}", {
  eager: true,
});

const photos = await Promise.all(
  galleryMeta.map(async (item) => {
    const entry = Object.entries(imageFiles).find(([path]) =>
      path.includes(`/${item.id}.`),
    );
    if (!entry) {
      throw new Error(
        `No se encontró la imagen para "${item.id}" en src/assets/gallery`,
      );
    }
    const source = entry[1].default;

    const full = await getImage({
      src: source,
      width: 1600,
      format: "webp",
      quality: 80,
    });
    const thumb = await getImage({
      src: source,
      width: 500,
      height: 500,
      fit: "cover",
      format: "webp",
      quality: 70,
    });

    return {
      ...item,
      src: full.src,
      thumbSrc: thumb.src,
      width: full.attributes.width,
      height: full.attributes.height,
    };
  }),
);
---

<BaseLayout
  title={title}
  description={description}
  sideBarActiveItemID="gallery"
>
  <div class="mb-6">
    <h1 class="text-2xl font-bold">Fotos de la huerta, balcón y demás</h1>
  </div>

  <section>
    <div class="grid grid-cols-2 gap-2 sm:grid-cols-3 sm:gap-3 lg:grid-cols-4">
      {
        photos.map((photo, i) => (
          <button
            class="gallery-item group relative aspect-square overflow-hidden rounded-xl bg-base-200"
            data-index={i}
            aria-label={`Ver foto: ${photo.title}`}
          >
            <img
              src={photo.thumbSrc}
              alt={photo.title}
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
            />
          </button>
        ))
      }
    </div>
  </section>

  <!-- Visor / Lightbox -->
  <div id="lightbox" class="fixed inset-0 z-50 hidden flex-col">
    <!-- Capa de fondo independiente: se atenúa durante el arrastre sin afectar a los controles -->
    <div id="lb-backdrop" class="absolute inset-0 z-0 bg-black"></div>

    <div
      class="relative z-10 flex items-center justify-between p-3 text-white sm:p-4"
    >
      <span id="lb-counter" class="text-sm opacity-70"></span>
      <div class="flex items-center gap-1">
        <button
          id="lb-info-toggle"
          aria-label="Más información"
          class="btn btn-ghost btn-circle btn-sm text-white"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            class="h-5 w-5"
          >
            <circle cx="12" cy="12" r="9"></circle>
            <line x1="12" y1="11" x2="12" y2="16"></line>
            <circle cx="12" cy="8" r="0.5" fill="currentColor"></circle>
          </svg>
        </button>
        <button
          id="lb-close"
          aria-label="Cerrar"
          class="btn btn-ghost btn-circle btn-sm text-white"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            class="h-5 w-5"
          >
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
    </div>

    <div
      id="lb-stage"
      class="relative z-10 flex flex-1 items-center justify-center overflow-hidden"
    >
      <button
        id="lb-prev"
        aria-label="Anterior"
        class="btn btn-ghost btn-circle absolute left-2 top-1/2 hidden -translate-y-1/2 text-white sm:flex"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          class="h-6 w-6"><polyline points="15 18 9 12 15 6"></polyline></svg
        >
      </button>

      <!-- touch-action:pinch-zoom evita el paneo nativo (que gestionamos a mano)
           pero deja intacto el pellizco nativo del navegador -->
      <img
        id="lb-img"
        src=""
        alt=""
        draggable="false"
        class="max-h-[75vh] max-w-[92vw] select-none object-contain"
        style="touch-action:pinch-zoom"
      />

      <button
        id="lb-next"
        aria-label="Siguiente"
        class="btn btn-ghost btn-circle absolute right-2 top-1/2 hidden -translate-y-1/2 text-white sm:flex"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          class="h-6 w-6"><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </button>
    </div>

    <div
      id="lb-info"
      class="absolute inset-x-0 bottom-0 z-10 max-h-[45vh] overflow-y-auto rounded-t-2xl bg-base-100 p-5 pb-8 text-base-content"
    >
      <div class="mx-auto mb-3 h-1.5 w-10 rounded-full bg-base-300 sm:hidden">
      </div>
      <h3 id="lb-title" class="text-lg font-bold"></h3>
      <p id="lb-desc" class="mt-1 text-sm opacity-80"></p>
      <div id="lb-tags" class="mt-3 flex flex-wrap gap-2"></div>
    </div>
  </div>
</BaseLayout>

<style>
  #lb-info {
    transform: translateY(100%);
    transition: transform 0.3s ease;
  }
  #lb-info.open {
    transform: translateY(0);
  }
  #lb-backdrop {
    opacity: 0.95;
    transition: opacity 0.25s ease;
  }
  #lb-img {
    transition: transform 0.25s ease;
  }
  /* El icono de info solo tiene sentido si no hay gesto táctil disponible */
  @media (pointer: coarse) {
    #lb-info-toggle {
      display: none;
    }
  }
  ::view-transition-old(gallery-photo),
  ::view-transition-new(gallery-photo) {
    animation-duration: 0.35s;
  }
</style>

<script define:vars={{ photos }}>
  function setupGallery() {
    const items = Array.from(document.querySelectorAll(".gallery-item"));
    const lightbox = document.getElementById("lightbox");
    const backdrop = document.getElementById("lb-backdrop");
    const stage = document.getElementById("lb-stage");
    const lbImg = document.getElementById("lb-img");
    const lbTitle = document.getElementById("lb-title");
    const lbDesc = document.getElementById("lb-desc");
    const lbTags = document.getElementById("lb-tags");
    const lbCounter = document.getElementById("lb-counter");
    const infoPanel = document.getElementById("lb-info");
    const btnClose = document.getElementById("lb-close");
    const btnInfo = document.getElementById("lb-info-toggle");
    const btnPrev = document.getElementById("lb-prev");
    const btnNext = document.getElementById("lb-next");

    let current = 0;
    let infoOpen = false;

    function canAnimate() {
      return (
        typeof document.startViewTransition === "function" &&
        !window.matchMedia("(prefers-reduced-motion: reduce)").matches
      );
    }

    function clearNames() {
      items.forEach((el) => (el.style.viewTransitionName = ""));
    }

    function render() {
      const p = photos[current];
      lbImg.src = p.src;
      lbImg.alt = p.title;
      lbImg.style.aspectRatio = `${p.width} / ${p.height}`;
      lbTitle.textContent = p.title;
      lbDesc.textContent = p.description;
      lbTags.innerHTML = "";
      (p.tags || []).forEach((tag) => {
        const span = document.createElement("span");
        span.className = "badge badge-outline badge-sm";
        span.textContent = `#${tag}`;
        lbTags.appendChild(span);
      });
      lbCounter.textContent = `${current + 1} / ${photos.length}`;
    }

    function withTransition(sourceIndex, mutate) {
      if (canAnimate()) {
        clearNames();
        const sourceEl = items[sourceIndex];
        if (sourceEl) sourceEl.style.viewTransitionName = "gallery-photo";
        lbImg.style.viewTransitionName = "gallery-photo";
        const transition = document.startViewTransition(mutate);
        transition.finished.finally(() => {
          clearNames();
          lbImg.style.viewTransitionName = "";
        });
      } else {
        mutate();
      }
    }

    // Deja imagen, fondo y panel de info en su estado "de reposo",
    // por si quedó algo a medias de un arrastre anterior.
    function resetDragStyles() {
      lbImg.style.transition = "";
      lbImg.style.transform = "";
      backdrop.style.transition = "";
      backdrop.style.opacity = "";
      infoPanel.style.transition = "";
      infoPanel.style.transform = "";
    }

    function open(index) {
      resetDragStyles();
      withTransition(index, () => {
        current = index;
        render();
        lightbox.classList.remove("hidden");
        lightbox.classList.add("flex");
        document.body.style.overflow = "hidden";
      });
    }

    function close() {
      infoOpen = false;
      infoPanel.classList.remove("open");
      withTransition(current, () => {
        lightbox.classList.add("hidden");
        lightbox.classList.remove("flex");
        document.body.style.overflow = "";
        resetDragStyles();
      });
    }

    function go(delta) {
      const newIndex = (current + delta + photos.length) % photos.length;
      withTransition(newIndex, () => {
        current = newIndex;
        render();
      });
    }

    function toggleInfo(force) {
      infoOpen = force !== undefined ? force : !infoOpen;
      infoPanel.classList.toggle("open", infoOpen);
    }

    items.forEach((btn, i) => {
      btn.addEventListener("click", () => open(i));
    });

    btnClose.addEventListener("click", close);
    btnInfo.addEventListener("click", () => toggleInfo());
    btnPrev.addEventListener("click", () => go(-1));
    btnNext.addEventListener("click", () => go(1));

    lightbox.addEventListener("click", (e) => {
      if (e.target === lightbox) close();
    });

    document.addEventListener("keydown", (e) => {
      if (lightbox.classList.contains("hidden")) return;
      if (e.key === "Escape") close();
      if (e.key === "ArrowRight") go(1);
      if (e.key === "ArrowLeft") go(-1);
      if (e.key === "ArrowUp") toggleInfo(true);
      if (e.key === "ArrowDown") toggleInfo(false);
    });

    // --- Gestos táctiles ---
    // Horizontal (cambiar de foto): se mantiene simple, todo-o-nada al soltar.
    // Vertical (info / cerrar): arrastre en tiempo real con muelle y velocidad,
    // estilo Google Photos / Instagram.

    const LOCK_THRESHOLD = 8; // px para decidir si el gesto es horizontal o vertical
    const SWIPE_THRESHOLD = 45; // umbral del swipe horizontal (sin cambios respecto a antes)

    const OPEN_INFO_DISTANCE = 140; // px de arrastre hacia arriba para "llenar" la revelación de info
    const OPEN_INFO_COMMIT = 0.35; // progreso (0-1) a partir del cual se da por completado
    const DISMISS_FADE_DISTANCE = 280; // px sobre los que se atenúa el fondo al arrastrar hacia abajo
    const DISMISS_COMMIT_PX = 120; // px de arrastre hacia abajo para considerar "cerrar"
    const FLING_VELOCITY = 0.55; // px/ms — un gesto rápido cuenta aunque recorra poca distancia

    let touchStartX = 0;
    let touchStartY = 0;
    let touching = false;
    let axis = null; // 'x' | 'y' | null mientras no se ha decidido
    let verticalMode = null; // 'open-info' | 'close-info' | 'dismiss'
    let infoPanelHeight = 0;
    let lastY = 0;
    let lastT = 0;
    let velocityY = 0;

    function setDragTransition(on) {
      lbImg.style.transition = on ? "" : "none";
      backdrop.style.transition = on ? "" : "none";
      infoPanel.style.transition = on ? "" : "none";
    }

    stage.addEventListener(
      "touchstart",
      (e) => {
        // TODO (zoom): si e.touches.length > 1, no iniciar el arrastre aquí y
        // dejar paso al futuro gesto de pellizco.
        if (e.touches.length > 1) return;
        touching = true;
        axis = null;
        verticalMode = null;
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
        lastY = touchStartY;
        lastT = e.timeStamp;
        velocityY = 0;
        infoPanelHeight = infoPanel.getBoundingClientRect().height || 300;
        setDragTransition(false);
      },
      { passive: true },
    );

    stage.addEventListener(
      "touchmove",
      (e) => {
        if (!touching || e.touches.length > 1) return;
        const x = e.touches[0].clientX;
        const y = e.touches[0].clientY;
        const dx = x - touchStartX;
        const dy = y - touchStartY;

        // Velocidad instantánea vertical (px/ms) para detectar "flings" cortos y rápidos
        const dt = e.timeStamp - lastT;
        if (dt > 0) velocityY = (y - lastY) / dt;
        lastY = y;
        lastT = e.timeStamp;

        // Decidir el eje del gesto una sola vez, tras un pequeño movimiento
        if (axis === null) {
          if (Math.abs(dx) < LOCK_THRESHOLD && Math.abs(dy) < LOCK_THRESHOLD)
            return;
          axis = Math.abs(dx) > Math.abs(dy) ? "x" : "y";
          if (axis === "y") {
            verticalMode =
              dy < 0
                ? infoOpen
                  ? null
                  : "open-info"
                : infoOpen
                  ? "close-info"
                  : "dismiss";
          }
        }

        if (axis !== "y" || !verticalMode) return;

        if (verticalMode === "open-info") {
          // Arrastrando hacia arriba con la info cerrada: el panel sigue el dedo
          const progress = Math.min(1, Math.max(0, -dy / OPEN_INFO_DISTANCE));
          infoPanel.style.transform = `translateY(${(1 - progress) * 100}%)`;
        } else if (verticalMode === "close-info") {
          // Arrastrando hacia abajo con la info abierta: el panel vuelve a bajar
          const progress = Math.min(1, Math.max(0, dy / infoPanelHeight));
          infoPanel.style.transform = `translateY(${progress * 100}%)`;
        } else if (verticalMode === "dismiss") {
          // Arrastrando hacia abajo con la info cerrada: la foto "se despega" y el fondo se atenúa
          const clampedDy = Math.max(0, dy);
          lbImg.style.transform = `translateY(${clampedDy}px)`;
          const fadeProgress = Math.min(1, clampedDy / DISMISS_FADE_DISTANCE);
          backdrop.style.opacity = String(0.95 - fadeProgress * 0.8);
        }
      },
      { passive: true },
    );

    stage.addEventListener(
      "touchend",
      (e) => {
        if (!touching) return;
        touching = false;

        const dx = e.changedTouches[0].clientX - touchStartX;
        const dy = e.changedTouches[0].clientY - touchStartY;

        // Siempre reactivamos las transiciones al soltar, aunque el gesto
        // se ignore (p. ej. arrastrar hacia arriba con la info ya abierta),
        // para no dejar "transition: none" pegado de cara al siguiente uso.
        setDragTransition(true);

        // Gesto horizontal: sin cambios, decisión simple al soltar
        if (axis === "x") {
          if (Math.abs(dx) >= SWIPE_THRESHOLD) {
            if (dx < 0) go(1);
            else go(-1);
          }
          axis = null;
          verticalMode = null;
          return;
        }

        if (axis !== "y" || !verticalMode) {
          axis = null;
          verticalMode = null;
          return;
        }

        if (verticalMode === "open-info") {
          const progress = Math.min(1, Math.max(0, -dy / OPEN_INFO_DISTANCE));
          const commit =
            progress > OPEN_INFO_COMMIT || velocityY < -FLING_VELOCITY;
          infoPanel.style.transform = "";
          infoOpen = commit;
          infoPanel.classList.toggle("open", commit);
        } else if (verticalMode === "close-info") {
          const progress = Math.min(1, Math.max(0, dy / infoPanelHeight));
          const commit =
            progress > OPEN_INFO_COMMIT || velocityY > FLING_VELOCITY;
          infoPanel.style.transform = "";
          infoOpen = !commit;
          infoPanel.classList.toggle("open", !commit);
        } else if (verticalMode === "dismiss") {
          const clampedDy = Math.max(0, dy);
          const commit =
            clampedDy > DISMISS_COMMIT_PX || velocityY > FLING_VELOCITY;
          if (commit) {
            lbImg.style.transform = "translateY(120%)";
            backdrop.style.opacity = "0";
            window.setTimeout(() => {
              lightbox.classList.add("hidden");
              lightbox.classList.remove("flex");
              document.body.style.overflow = "";
              resetDragStyles();
            }, 220);
          } else {
            lbImg.style.transform = "";
            backdrop.style.opacity = "";
          }
        }

        axis = null;
        verticalMode = null;
      },
      { passive: true },
    );
  }

  document.addEventListener("astro:page-load", setupGallery);
</script>
